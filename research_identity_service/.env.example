# API configuration
# Either OpenRouter or NVIDIA API keys can be supplied.
# By default, if NVIDIA_API_KEY is present, it will run NVIDIA models.
# Example key: nvapi-xxxxx...
NVIDIA_API_KEY=
# Example key: sk-or-v1-xxxx...
OPENROUTER_API_KEY=

# Server Configuration
PORT=8001
HOST=0.0.0.0

# Database Configuration (SQLite)
DATABASE_URL=sqlite:///data/cache/app.db

# Output directory for research_profile.json
OUTPUT_DIR=data/output
